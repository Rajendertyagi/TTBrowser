<Window x:Class="TTBrowser.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="TTBrowser CefSharp" Height="900" Width="1400" WindowStyle="None" Background="#202124">
<WindowChrome.WindowChrome><WindowChrome CaptionHeight="48" ResizeBorderThickness="6"/></WindowChrome.WindowChrome>
<Window.Resources>
<Style x:Key="Btn" TargetType="Button"><Setter Property="Width" Value="32"/><Setter Property="Height" Value="32"/><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#9AA0A6"/><Setter Property="BorderThickness" Value="0"/><Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/></Style>
</Window.Resources>
<DockPanel>
<Grid DockPanel.Dock="Top" Height="48" Background="#202124">
<StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0,0,0">
<TabControl x:Name="TabStrip" Background="Transparent" BorderThickness="0" SelectionChanged="TabStrip_SelectionChanged" WindowChrome.IsHitTestVisibleInChrome="True"/>
<Button Content="+" Style="{StaticResource Btn}" Click="NewTab_Click" Margin="4,0,0,4"/>
</StackPanel>
<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
<Button Content="—" Width="46" Height="32" Background="Transparent" Foreground="#E8EAED" BorderThickness="0" Click="Minimize_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
<Button Content="□" Width="46" Height="32" Background="Transparent" Foreground="#E8EAED" BorderThickness="0" Click="Maximize_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
<Button Content="✕" Width="46" Height="32" Background="Transparent" Foreground="#E8EAED" BorderThickness="0" Click="Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"/>
</StackPanel>
</Grid>
<Grid DockPanel.Dock="Top" Height="56" Background="#202124">
<Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
<Button Style="{StaticResource Btn}" Content="←" Click="Back_Click"/>
<Button Style="{StaticResource Btn}" Content="→" Click="Forward_Click"/>
<Button Style="{StaticResource Btn}" Content="⟳" Click="Reload_Click"/>
<Button Style="{StaticResource Btn}" Content="⌂" Click="Home_Click"/>
</StackPanel>
<Border Grid.Column="1" Background="#2A2B2F" CornerRadius="24" Height="40" Margin="8,0">
<TextBox x:Name="AddressBar" Background="Transparent" BorderThickness="0" Foreground="#E8EAED" VerticalAlignment="Center" Margin="16,0" FontSize="14" KeyDown="AddressBar_KeyDown"/>
</Border>
<Button Grid.Column="2" Style="{StaticResource Btn}" Content="🗒" Click="Logs_Click" ToolTip="Open logs"/>
</Grid>
<TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Foreground="#9AA0A6" Margin="8,4" FontSize="12" Text="Ready"/>
<Grid x:Name="ContentHost" Background="#202124"/>
</DockPanel>
</Window>
